# PostgreSQL (async SQLAlchemy URL)
# Local example:
# DATABASE_URL=postgresql+asyncpg://postgres:YOUR_PASSWORD@localhost:5432/api_pulse
#
# Supabase (Project Settings -> Database -> Connection string -> URI, Direct connection):
# DATABASE_URL=postgresql+asyncpg://postgres.[PROJECT-REF]:[YOUR-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres
# DATABASE_SSL=require

DATABASE_URL=postgresql+asyncpg://postgres:YOUR_PASSWORD@localhost:5432/api_pulse
API_PORT=8080

# JWT
SECRET_KEY=change-me-to-a-long-random-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
